<?xml version="1.0" encoding="utf-8"?>
<!--
  Base web.config. `dotnet publish` injects the <aspNetCore> element and the
  ASP.NET Core Module handler into this file automatically — do not add them here.

  Two IIS defaults would otherwise block the admin PUT /api/cv endpoint:
    1. The WebDAV module intercepts PUT/DELETE and returns 403/405 — removed below.
    2. Request Filtering can reject non-GET/POST verbs — PUT/DELETE allowed below.
-->
<configuration>
  <system.webServer>
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
    </handlers>
    <security>
      <requestFiltering>
        <verbs allowUnlisted="true">
          <add verb="PUT" allowed="true" />
          <add verb="DELETE" allowed="true" />
        </verbs>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>

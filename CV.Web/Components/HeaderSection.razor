<header class="cv-header">
    <div class="header-name">
        <h1>@Header.Name</h1>
        <p class="header-title">@Header.Title</p>
    </div>
    <div class="header-contact">
        @if (!string.IsNullOrWhiteSpace(Header.Location))
        {
            <div class="contact-item">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>@Header.Location</span>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Header.Phone))
        {
            <div class="contact-item">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>@Header.Phone</span>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Header.Email))
        {
            <div class="contact-item">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:@Header.Email">@Header.Email</a>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Header.LinkedInUrl))
        {
            <div class="contact-item">
                <svg class="icon" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 17V10.21H6.09V17h2.25zM7.21 9.27a1.3 1.3 0 1 0 0-2.61 1.3 1.3 0 0 0 0 2.61zM18 17v-3.72c0-1.94-1.04-2.85-2.42-2.85-1.12 0-1.62.62-1.9 1.05V10.2h-2.25V17h2.25v-3.79c0-.2.01-.4.07-.54.16-.4.52-.81 1.13-.81.8 0 1.12.61 1.12 1.5V17H18z"/></svg>
                <a href="@Header.LinkedInUrl" target="_blank" rel="noopener">LinkedIn</a>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Header.GitHubUrl))
        {
            <div class="contact-item">
                <svg class="icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49v-1.7c-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.58 2.36 1.12 2.93.86.09-.67.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.34 9.34 0 0 1 12 6.84c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9v2.82c0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"/></svg>
                <a href="@Header.GitHubUrl" target="_blank" rel="noopener">GitHub</a>
            </div>
        }
    </div>
</header>

@code {
    [Parameter, EditorRequired] public HeaderDto Header { get; set; } = new();
}

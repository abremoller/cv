<section class="cv-section">
    <h2 class="section-title">Skills</h2>
    <div class="skills-list">
        @foreach (var skill in Skills)
        {
            var years = DateTime.Now.Year - skill.SinceYear;
            <div class="skill-item">
                <div class="skill-header">
                    <span class="skill-name">@skill.Name</span>
                    <span class="skill-years">@years yr@(years != 1 ? "s" : "")</span>
                </div>
                <div class="skill-bar">
                    <div class="skill-bar-fill" style="width: @((int)(years / (double)MaxYears * 100))%"></div>
                </div>
            </div>
        }
    </div>

    @if (CurrentFocus.Count > 0)
    {
        <h3 class="skills-subhead">Current Focus</h3>
        <div class="focus-list">
            @foreach (var focus in CurrentFocus)
            {
                <span class="focus-tag">@focus</span>
            }
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public List<SkillDto> Skills { get; set; } = [];
    [Parameter] public List<string> CurrentFocus { get; set; } = [];

    // Years of experience are derived from each skill's start year, so they
    // always read "up to the present day" without manual maintenance.
    private int MaxYears => Skills.Count == 0 ? 1 : Math.Max(1, Skills.Max(s => DateTime.Now.Year - s.SinceYear));
}
